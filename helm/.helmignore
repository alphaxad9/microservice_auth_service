# Patterns to ignore when building packages.
# This supports shell glob matching, relative path matching, and
# negation (prefixed with !). Only one pattern per line.
.DS_Store
# Common VCS dirs
.git/
.gitignore
.bzr/
.bzrignore
.hg/
.hgignore
.svn/
# Common backup files
*.swp
*.bak
*.tmp
*.orig
*~
# Various IDEs
.project
.idea/
*.tmproj
.vscode/
# Ignore version control
.git
.gitignore

# Ignore binaries and helper tools
bin/
act

# Ignore IDE files
.vscode/
.idea/
*.swp
*.swo

# Ignore common OS files
.DS_Store
Thumbs.db

# Ignore test files if they aren't part of the chart
tests/